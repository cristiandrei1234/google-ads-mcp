# Production environment for docker-compose.prod.yml.
# Copy to .env.prod and fill in real values. NEVER commit .env.prod.

# Public domain (DNS A/AAAA must point at this host; Caddy gets TLS for it).
DOMAIN=mcp.your-agency.com

# Postgres password (used by both the db and the app's DATABASE_URL).
POSTGRES_PASSWORD=change-me-strong

# Google Ads API (also used for Google social login).
GOOGLE_ADS_CLIENT_ID=your_client_id
GOOGLE_ADS_CLIENT_SECRET=your_client_secret
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
# Optional single-operator fallback (leave empty in multi-tenant prod):
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Encryption key for refresh tokens at rest — openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Better Auth — openssl rand -base64 32 for the secret.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://mcp.your-agency.com

# Origin of your own web app (for CORS), if any.
WEB_APP_ORIGIN=https://app.your-agency.com

# Transactional email (Resend). When set, verification/reset/invitation emails
# are delivered and email verification is required by default.
RESEND_API_KEY=
EMAIL_FROM="Google Ads MCP <no-reply@your-agency.com>"
# Force email verification on/off (defaults: on when RESEND is configured).
EMAIL_VERIFICATION=on

LOG_LEVEL=info
