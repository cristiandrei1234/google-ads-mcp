DATABASE_URL=postgresql://postgres:postgres@localhost:5432/google_ads_mcp?schema=public
GOOGLE_ADS_CLIENT_ID=your_client_id
GOOGLE_ADS_CLIENT_SECRET=your_client_secret
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
# Optional fallback for single-operator mode
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
GOOGLE_ADS_LOGIN_CUSTOMER_ID=123-456-7890 (optional for list customers)
MERCHANT_CENTER_ID=your_merchant_center_id (optional)
LOG_LEVEL=info

# Encryption key for Google Ads refresh tokens at rest.
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Better Auth (multi-tenant employee auth) — required once HTTP transport is wired.
# Generate the secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Transactional email (Resend). Leave RESEND_API_KEY empty in dev (emails are
# logged, not sent, and email verification stays off).
RESEND_API_KEY=
EMAIL_FROM="Google Ads MCP <no-reply@example.com>"
# EMAIL_VERIFICATION=on|off  (default: on when RESEND_API_KEY is set)
